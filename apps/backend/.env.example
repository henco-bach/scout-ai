ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=sqlite+aiosqlite:///./data/scout-ai.db
STORAGE_DIR=./data/uploads

# AI report generation. "mock" needs no API key and is the default.
AI_PROVIDER=mock

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3-27b-it

# Football-specific ball/player/goalkeeper/referee detection (Roboflow-hosted
# model, downloaded and run locally via the `inference` package). Free tier
# API key from roboflow.com.
ROBOFLOW_API_KEY=
